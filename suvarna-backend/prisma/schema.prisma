generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id        String     @id @default(uuid())
  username  String     @unique
  password  String
  createdAt DateTime   @default(now())
  purchases Purchase[]
}

model Admin {
  id         String     @id @default(uuid())
  username   String     @unique
  branchName String
  state      String
  password   String
  role       String     @default("ADMIN")
  createdAt  DateTime   @default(now())
  createdBy  String
  purchases  Purchase[]
}

model GoldPurchase {
  id            String   @id @default(uuid())
  companyName   String
  goldType      String
  grams         Float
  pricePerGram  Float
  totalAmount   Float
  purchaseDate  DateTime
  invoiceNumber String?
  paymentMode   String?
  notes         String?
  createdBy     String
  createdAt     DateTime @default(now())
}

model GoldJobWork {
  id                String    @id @default(uuid())
  companyName       String
  productType       String
  goldGivenType     String
  goldGivenGrams    Float
  makingCharge      Float?
  status            String    @default("PENDING")
  dateGiven         DateTime
  dateReceived      DateTime?
  wastageGrams      Float?
  returnedGoldGrams Float?
  notes             String?
  createdBy         String
  createdAt         DateTime  @default(now())
}

model Staff {
  id            String   @id @default(uuid())
  fullName      String
  dateOfJoining DateTime
  monthlySalary Float
  gender        String
  phoneNumber   String   @unique
  aadharNumber  String   @unique
  createdAt     DateTime @default(now())
  createdBy     String
}

model Product {
  id              String         @id @default(uuid())
  name            String
  metalType       String
  carats          String
  category        String         @default("others")
  bodyPart        String         @default("others")
  grams           Float
  stoneWeight     Float          @default(0)
  netWeight       Float          @default(0)
  quantity        Int            @default(1)
  huid            String?
  uniqueCode      String         @unique
  sku             String         @unique
  isSold          Boolean        @default(false)
  manufactureDate DateTime
  createdAt       DateTime       @default(now())
  soldAt          DateTime?
  branchName      String         @default("Gajuwaka")
  va              Float          @default(2.5)
  purchaseItems   PurchaseItem[]
}

model Purchase {
  id                        String         @id @default(uuid())
  customerName              String
  emailid                   String?
  Address                   String?
  totalAmount               Float
  discountAmount            Float
  finalAmount               Float
  phoneNumber               String
  paymentId                 String?
  paymentStatus             String         @default("PENDING")
  purchasedAt               DateTime       @default(now())
  adminId                   String?
  superAdminId              String?
  cgstAmount                Float          @default(2500)
  sgstAmount                Float          @default(2500)
  excahngejewellrygrams     Float?
  excahngejewellryname      String?
  jewelleryexchangediscount Float?
  admin                     Admin?         @relation(fields: [adminId], references: [id])
  superAdmin                SuperAdmin?    @relation(fields: [superAdminId], references: [id])
  items                     PurchaseItem[]
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  productId  String
  name       String
  grams      Float
  cost       Float
  product    Product  @relation(fields: [productId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
}

model Scheme {
  id               String           @id @default(uuid())
  name             String
  durationMonths   Int
  monthlyAmount    Float
  maturityAmount   Float
  completionCoupon String?          // You can use this as a prefix (e.g., "GOLD-")
  createdAt        DateTime         @default(now())
  
  // Track all customers enrolled in this scheme
  customers        CustomerScheme[]
  
  // Array to store all unique coupon codes generated under this scheme
  issuedCouponCodes String[] 
  
  // Relation to the detailed Coupon records
  coupons          Coupon[]
}

model Customer {
  id        String           @id @default(uuid())
  name      String
  username  String           @unique
  password  String
  phone     String
  createdAt DateTime         @default(now())
  mpin      String?
  
  schemes   CustomerScheme[]
  coupons   Coupon[]         // Relation to all coupons owned by this customer
}

model CustomerScheme {
  id               String   @id @default(uuid())
  customerId       String
  schemeId         String
  totalPaid        Float    @default(0)
  remainingAmount  Float
  installmentsPaid Int      @default(0)
  installmentsLeft Int
  isCompleted      Boolean  @default(false)
  couponGenerated  Boolean  @default(false)
  startDate        DateTime @default(now())
  
  customer         Customer @relation(fields: [customerId], references: [id])
  scheme           Scheme   @relation(fields: [schemeId], references: [id])

  // Link to the specific unique coupon generated for this enrollment
  coupon           Coupon?
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique   // The unique code generated for the user
  couponValue Float             // Captured from Scheme.maturityAmount at enrollment
  isUsed      Boolean  @default(false)
  isActive    Boolean  @default(true) // Active by default once assigned to a user
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  // Link to the specific Enrollment (to track payments/progress)
  customerSchemeId String @unique
  customerScheme   CustomerScheme @relation(fields: [customerSchemeId], references: [id])

  // Link to the Customer (The Owner)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  // Link to the Parent Scheme Type
  schemeId    String
  scheme      Scheme   @relation(fields: [schemeId], references: [id])
}model OtpVerification {
  id            String    @id @default(cuid())
  phoneNumber   String    @db.VarChar(15)
  otpCode       String    @db.VarChar(6)
  purpose       String    @db.VarChar(50)
  requestedById String?
  attempts      Int       @default(0)
  isUsed        Boolean   @default(false)
  expiresAt     DateTime
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([phoneNumber])
  @@index([purpose])
  @@index([phoneNumber, purpose])
}

model ProductImgs {
  id          String   @id @default(uuid())
  title       String
  description String?
  weight      Float
  image       Bytes
  mimeType    String   @default("image/jpeg")
  metalType   String   @default("gold")
  carats      String   @default("24k")
  createdAt   DateTime @default(now())
}
