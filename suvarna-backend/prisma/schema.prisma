generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id        String     @id @default(uuid())
  username  String     @unique
  password  String
  createdAt DateTime   @default(now())
  purchases Purchase[]
}

model Admin {
  id         String     @id @default(uuid())
  username   String     @unique
  branchName String
  state      String
  password   String
  role       String     @default("ADMIN")
  createdAt  DateTime   @default(now())
  createdBy  String
  purchases  Purchase[]
}

model GoldPurchase {
  id            String   @id @default(uuid())
  companyName   String
  goldType      String
  grams         Float
  pricePerGram  Float
  totalAmount   Float
  purchaseDate  DateTime
  invoiceNumber String?
  paymentMode   String?
  notes         String?
  createdBy     String
  createdAt     DateTime @default(now())
}

model GoldJobWork {
  id                String    @id @default(uuid())
  companyName       String
  productType       String
  goldGivenType     String
  goldGivenGrams    Float
  makingCharge      Float?
  status            String    @default("PENDING")
  dateGiven         DateTime
  dateReceived      DateTime?
  wastageGrams      Float?
  returnedGoldGrams Float?
  notes             String?
  createdBy         String
  createdAt         DateTime  @default(now())
}

model Staff {
  id            String   @id @default(uuid())
  fullName      String
  dateOfJoining DateTime
  monthlySalary Float
  gender        String
  phoneNumber   String   @unique
  aadharNumber  String   @unique
  createdAt     DateTime @default(now())
  createdBy     String
}

model Product {
  id              String         @id @default(uuid())
  name            String
  metalType       String
  carats          String         // Stores Gold Carats or Silver Purity
  category        String         @default("others")// e.g., "Bangle", "Ring", "Necklace", "Earring"
  bodyPart        String         @default("others")// e.g., "Wrist", "Fingers", "Neck", "Ear"
  grams           Float          // Metal weight
  stoneWeight     Float          @default(0)
  netWeight       Float          @default(0) // Sum of grams + stoneWeight
  quantity        Int            @default(1)
  huid            String?        // Optional HUID string
  uniqueCode      String         @unique
  sku             String         @unique
  isSold          Boolean        @default(false)
  manufactureDate DateTime
  createdAt       DateTime       @default(now())
  soldAt          DateTime?
  purchaseItems   PurchaseItem[]
}

model Purchase {
  id             String         @id @default(uuid())
  customerName   String
  totalAmount    Float
  gstAmount      Float
  discountAmount Float
  finalAmount    Float
  phoneNumber    String
  paymentId      String?
  paymentStatus  String         @default("PENDING")
  purchasedAt    DateTime       @default(now())
  adminId        String?
  superAdminId   String?
  admin          Admin?         @relation(fields: [adminId], references: [id])
  superAdmin     SuperAdmin?    @relation(fields: [superAdminId], references: [id])
  items          PurchaseItem[]
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  productId  String
  name       String
  grams      Float
  cost       Float
  product    Product  @relation(fields: [productId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
}

model Scheme {
  id               String           @id @default(uuid())
  name             String
  durationMonths   Int
  monthlyAmount    Float
  maturityAmount   Float
  completionCoupon String?
  createdAt        DateTime         @default(now())
  customers        CustomerScheme[]
}

model Customer {
  id        String           @id @default(uuid())
  name      String
  username  String           @unique
  password  String
  phone     String
  createdAt DateTime         @default(now())
  schemes   CustomerScheme[]
}

model CustomerScheme {
  id               String   @id @default(uuid())
  customerId       String
  schemeId         String
  totalPaid        Float    @default(0)
  remainingAmount  Float
  installmentsPaid Int      @default(0)
  installmentsLeft Int
  isCompleted      Boolean  @default(false)
  couponGenerated  Boolean  @default(false)
  startDate        DateTime @default(now())
  customer         Customer @relation(fields: [customerId], references: [id])
  scheme           Scheme   @relation(fields: [schemeId], references: [id])
}

model OtpVerification {
  id            String    @id @default(cuid())
  phoneNumber   String    @db.VarChar(15)
  otpCode       String    @db.VarChar(6)
  purpose       String    @db.VarChar(50)
  requestedById String?
  attempts      Int       @default(0)
  isUsed        Boolean   @default(false)
  expiresAt     DateTime
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([phoneNumber])
  @@index([purpose])
  @@index([phoneNumber, purpose])
}

model ProductImgs {
  id          String   @id @default(uuid())
  title       String
  description String?
  weight      Float
  image       Bytes    // Binary image storage
  mimeType    String   @default("image/jpeg")  // ✅ add this
  metalType   String   @default("gold") 
  carats      String   @default("24k")
  createdAt   DateTime @default(now())
}