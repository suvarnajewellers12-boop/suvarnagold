generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id        String     @id @default(uuid())
  username  String     @unique
  password  String
  createdAt DateTime   @default(now())
  purchases Purchase[]
}

model Admin {
  id         String     @id @default(uuid())
  username   String     @unique
  branchName String
  state      String
  password   String
  Address    String     @default("D.No. 13-1-12, Main Road,Near YSR Statue, New Gajuwaka,Visakhapatnam - 530026,Andhra Pradesh")
  Gmail      String     @default("suvarnajewellers12@gmail.com")
  role       String     @default("ADMIN")
  createdAt  DateTime   @default(now())
  createdBy  String
  purchases  Purchase[]
}

model GoldPurchase {
  id            String   @id @default(uuid())
  companyName   String
  goldType      String
  grams         Float
  pricePerGram  Float
  totalAmount   Float
  purchaseDate  DateTime
  invoiceNumber String?
  paymentMode   String?
  notes         String?
  createdBy     String
  createdAt     DateTime @default(now())
}

model GoldJobWork {
  id                String    @id @default(uuid())
  workerName        String?   // Added ? to allow nulls for existing rows
  totalGrams        Float?    // Added ? to allow nulls for existing rows
  productType       String?
  advancePaid       Float     @default(0)
  makingCharge      Float?
  status            String    @default("PENDING")
  dateGiven         DateTime  @default(now())
  dateReceived      DateTime?
  wastageGrams      Float?
  returnedGoldGrams Float?
  notes             String?
  createdBy         String
  createdAt         DateTime  @default(now())
  totalPaid         Float? @default(0)
  
  // The relation field for orders
  assignedOrders    Order[]   
}

model Order {
  id               String        @id @default(uuid())
  orderId          String        @unique // e.g., OR-2026-1001
  customerName     String
  phoneNumber      String
  itemName         String
  itemDescription  String?
  metalType        String        // GOLD / SILVER
  purity           String
  liveRate         Float
  givenMetalGrams  Float
  addedMetalGrams  Float
  stoneWeight      Float
  netWeight        Float
  grossWeight      Float
  vaPercentage     Float
  stoneCost        Float
  gst        Float
  totalAmount      Float
  advanceCash      Float
  discountAmount   Float? @default(10000)
  balanceAmount    Float
  deadlineDate     DateTime
  createdAt        DateTime      @default(now())
  createdBy        String

  // ================= WORKFLOW & RELATIONSHIP FIELDS =================
  
  // 1. Status tracks the lifecycle of the customer's item
  // Values: "NOT ASSIGNED" | "ASSIGNED" | "COMPLETED" | "DELIVERED"
  status           String        @default("NOT ASSIGNED") 

  // 2. The Foreign Key: Stores the ID of the JobWork record when assigned
  jobWorkId        String?       

  // 3. The Relation: This allows you to do: prisma.order.findUnique().jobWork()
  jobWork          GoldJobWork?  @relation(fields: [jobWorkId], references: [id])
}
model Staff {
  id            String   @id @default(uuid())
  fullName      String
  dateOfJoining DateTime
  monthlySalary Float
  gender        String
  phoneNumber   String   @unique
  aadharNumber  String   @unique
  createdAt     DateTime @default(now())
  createdBy     String
}

model Product {
  id              String         @id @default(uuid())
  name            String
  metalType       String
  carats          String
  category        String         @default("others")
  bodyPart        String         @default("others")
  grams           Float
  stoneWeight     Float          @default(0)
  netWeight       Float          @default(0)
  quantity        Int            @default(1)
  huid            String?
  uniqueCode      String         @unique
  sku             String         @unique
  isSold          Boolean        @default(false)
  manufactureDate DateTime
  createdAt       DateTime       @default(now())
  soldAt          DateTime?
  branchName      String         @default("Gajuwaka")
  va              Float          @default(2.5)
  stoneCost       Float          @default(0)
  purchaseItems   PurchaseItem[]
}




model Purchase {
  id                        String         @id @default(uuid())
  customerName              String
  emailid                   String?
  Address                   String?
  totalAmount               Float
  discountAmount            Float
  finalAmount               Float
  phoneNumber               String
  paymentId                 String?        @default("MANUAL_POS")
  paymentStatus             String         @default("SUCCESS")
  purchasedAt               DateTime       @default(now())
  adminId                   String?
  superAdminId              String?
  cgstAmount                Float          @default(0)
  sgstAmount                Float          @default(0)
  excahngejewellrygrams     Float?
  excahngejewellryname      String?
  jewelleryexchangediscount Float?
  couponDiscount            Float?         @default(0)
  cardAmount                Float          @default(0)
  cashAmount                Float          @default(0)
  chequeAmount              Float          @default(0)
  upiAmount                 Float          @default(0)
  invoice                   String         @default("svj-234")
  admin                     Admin?         @relation(fields: [adminId], references: [id])
  superAdmin                SuperAdmin?    @relation(fields: [superAdminId], references: [id])
  items                     PurchaseItem[]
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  productId  String
  name       String
  grams      Float
  cost       Float
  isReturned Boolean  @default(false)
  product    Product  @relation(fields: [productId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
}

model Scheme {
  id             String           @id @default(uuid())
  name           String
  durationMonths Int
  monthlyAmount  Float
  createdAt      DateTime         @default(now())
  isWeightBased  Boolean          @default(false)
  maturityMonths Int?
  coupons        Coupon[]
  enrollments    CustomerScheme[]
}

model CreditNote {
  id          String       @id @default(uuid())
  productName String
  grams       Float
  carats      String?
  stoneWeight Float?
  overallCost Float
  couponId    String
  createdAt   DateTime     @default(now())
  coupon      ReturnCoupon @relation(fields: [couponId], references: [id])
}

model CustomerScheme {
  id               String           @id @default(uuid())
  customerId       String
  schemeId         String
  totalPaid        Float            @default(0)
  remainingAmount  Float
  installmentsPaid Int              @default(0)
  installmentsLeft Int
  isCompleted      Boolean          @default(false)
  startDate        DateTime         @default(now())
  accumulatedGrams Float            @default(0)
  coupon           Coupon?
  customer         Customer         @relation(fields: [customerId], references: [id])
  scheme           Scheme           @relation(fields: [schemeId], references: [id])
  payments         PaymentHistory[]
}

model PaymentHistory {
  id               String         @id @default(uuid())
  customerSchemeId String
  amountPaid       Float
  liveRate24K      Float?
  gramsAdded       Float?
  paidAt           DateTime       @default(now())
  customerScheme   CustomerScheme @relation(fields: [customerSchemeId], references: [id])
}

model Coupon {
  id               String          @id @default(uuid())
  code             String          @unique
  isUsed           Boolean         @default(false)
  usedAt           DateTime?
  createdAt        DateTime        @default(now())
  customerSchemeId String?         @unique
  customerId       String
  schemeId         String?
  isActive         Boolean         @default(true)
  totalCashValue   Float           @default(0)
  totalWeightGrams Float           @default(0)
  description      String?
  type             String          @default("WEIGHT")
  value            Float           @default(0)
  customer         Customer        @relation(fields: [customerId], references: [id])
  customerScheme   CustomerScheme? @relation(fields: [customerSchemeId], references: [id])
  scheme           Scheme?         @relation(fields: [schemeId], references: [id])
}

model Customer {
  id        String           @id @default(uuid())
  name      String
  username  String           @unique
  password  String
  phone     String
  createdAt DateTime         @default(now())
  mpin      String?
  coupons   Coupon[]
  schemes   CustomerScheme[]
}

model OtpVerification {
  id            String    @id @default(cuid())
  phoneNumber   String    @db.VarChar(15)
  otpCode       String    @db.VarChar(6)
  purpose       String    @db.VarChar(50)
  requestedById String?
  attempts      Int       @default(0)
  isUsed        Boolean   @default(false)
  expiresAt     DateTime
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([phoneNumber])
  @@index([purpose])
  @@index([phoneNumber, purpose])
}

model ReturnCoupon {
  id          String       @id @default(uuid())
  code        String       @unique
  cashAmount  Float
  isUsed      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  invoice     String       @default("#svn")
  pastinvoice String       @default("svn-invoice")

  creditNotes CreditNote[]
}

model ProductImgs {
  id          String   @id @default(uuid())
  title       String
  description String?
  weight      Float
  image       Bytes
  mimeType    String   @default("image/jpeg")
  metalType   String   @default("gold")
  carats      String   @default("24k")
  createdAt   DateTime @default(now())
}
