generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id        String     @id @default(uuid())
  username  String     @unique
  password  String
  createdAt DateTime   @default(now())
  purchases Purchase[]
}

model Admin {
  id         String     @id @default(uuid())
  username   String     @unique
  branchName String
  state      String
  password   String
  role       String     @default("ADMIN")
  createdAt  DateTime   @default(now())
  createdBy  String
  purchases  Purchase[]
}

model GoldPurchase {
  id            String   @id @default(uuid())
  companyName   String
  goldType      String
  grams         Float
  pricePerGram  Float
  totalAmount   Float
  purchaseDate  DateTime
  invoiceNumber String?
  paymentMode   String?
  notes         String?
  createdBy     String
  createdAt     DateTime @default(now())
}

model GoldJobWork {
  id                String    @id @default(uuid())
  companyName       String
  productType       String
  goldGivenType     String
  goldGivenGrams    Float
  makingCharge      Float?
  status            String    @default("PENDING")
  dateGiven         DateTime
  dateReceived      DateTime?
  wastageGrams      Float?
  returnedGoldGrams Float?
  notes             String?
  createdBy         String
  createdAt         DateTime  @default(now())
}

model Staff {
  id            String   @id @default(uuid())
  fullName      String
  dateOfJoining DateTime
  monthlySalary Float
  gender        String
  phoneNumber   String   @unique
  aadharNumber  String   @unique
  createdAt     DateTime @default(now())
  createdBy     String
}

model Product {
  id              String         @id @default(uuid())
  name            String
  metalType       String
  carats          String
  category        String         @default("others")
  bodyPart        String         @default("others")
  grams           Float
  stoneWeight     Float          @default(0)
  stoneCost       Float          @default(0)
  netWeight       Float          @default(0)
  quantity        Int            @default(1)
  huid            String?
  uniqueCode      String         @unique
  sku             String         @unique
  isSold          Boolean        @default(false)
  manufactureDate DateTime
  createdAt       DateTime       @default(now())
  soldAt          DateTime?
  branchName      String         @default("Gajuwaka")
  va              Float          @default(2.5)
  purchaseItems   PurchaseItem[]
}

model Purchase {
  id                        String         @id @default(uuid())
  customerName              String
  emailid                   String?
  Address                   String?
  phoneNumber               String
  invoice                   String @default("svj-234")
  
  // Financial Totals
  totalAmount               Float          // Subtotal
  discountAmount            Float          // Manager Waiver
  cgstAmount                Float          @default(0)
  sgstAmount                Float          @default(0)
  jewelleryexchangediscount Float?         // Old gold value
  finalAmount               Float          // Final payable amount

  // Multi-Modal Payment Breakdown
  cashAmount                Float          @default(0)
  upiAmount                 Float          @default(0)
  cardAmount                Float          @default(0) // Debit/Credit
  chequeAmount              Float          @default(0)
  
  // Transaction Metadata
  paymentId                 String?        @default("MANUAL_POS")
  paymentStatus             String         @default("SUCCESS")
  purchasedAt               DateTime       @default(now())
  
  // Old Jewellery Exchange Metadata
  excahngejewellrygrams     Float?
  excahngejewellryname      String?
  
  // Relations
  adminId                   String?
  superAdminId              String?
  admin                     Admin?         @relation(fields: [adminId], references: [id])
  superAdmin                SuperAdmin?    @relation(fields: [superAdminId], references: [id])
  items                     PurchaseItem[]
}
model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  productId  String
  name       String
  grams      Float
  cost       Float
  product    Product  @relation(fields: [productId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  isReturned Boolean  @default(false) // <--- Add this line
}
// ==========================================
// 1. SCHEME BLUEPRINT
// ==========================================
model Scheme {
  id                String           @id @default(uuid())
  name              String
  isWeightBased     Boolean          @default(false) // Toggle: True (Cat-B) | False (Cat-A)
  durationMonths    Int              // Total Tenure (e.g., 11)
  monthlyAmount     Float            // Fixed installment (e.g., 22000)
  maturityMonths    Int?             // 1-25 Dropdown (Only for Cat-A)
  createdAt         DateTime         @default(now())
  
  enrollments       CustomerScheme[]
  coupons           Coupon[]
}

model CreditNote {
  id              String       @id @default(uuid())
  productName     String
  grams           Float
  carats          String?
  stoneWeight     Float?
  overallCost     Float
  
  // Relation to the parent coupon
  couponId        String
  coupon          ReturnCoupon @relation(fields: [couponId], references: [id])
  
  createdAt       DateTime     @default(now())
}

// ==========================================
// 2. CUSTOMER ENROLLMENT (The Digital Vault)
// ==========================================
model CustomerScheme {
  id                String           @id @default(uuid())
  customerId        String
  schemeId          String
  
  // Progress Tracking
  totalPaid         Float            @default(0)
  installmentsPaid  Int              @default(0)
  installmentsLeft  Int
  
  // LIVE VAULT: Updated continuously for Category-B
  accumulatedGrams  Float            @default(0) 
  remainingAmount   Float 
  
  isCompleted       Boolean          @default(false)
  startDate         DateTime         @default(now())
  
  customer          Customer         @relation(fields: [customerId], references: [id])
  scheme            Scheme           @relation(fields: [schemeId], references: [id])
  payments          PaymentHistory[]
  coupon            Coupon?          // One-to-one link to the live coupon
}

// ==========================================
// 3. PAYMENT HISTORY (The Audit Trail)
// ==========================================
model PaymentHistory {
  id               String         @id @default(uuid())
  customerSchemeId String
  amountPaid       Float
  
  // Captured at the exact moment of payment
  liveRate24K      Float?         // Fetched from API
  gramsAdded       Float?         // amountPaid / liveRate24K
  
  paidAt           DateTime       @default(now())
  customerScheme   CustomerScheme @relation(fields: [customerSchemeId], references: [id])
}

// ==========================================
// 4. COUPON (The "Avail Offer" Certificate)
// ==========================================
model Coupon {
  id               String          @id @default(uuid())
  code             String          @unique // e.g., RTN-XXXXXX or SUV-2026-XXXX
  
  // NEW FIELDS for Return/Manual Logic
  type             String          @default("WEIGHT") // "WEIGHT" for schemes, "CASH" for returns
  value            Float           @default(0)        // Used specifically for CASH type returns
  description      String?         // To store "Return Credit for Bill #123"

  // Value for Category-A (Gold Schemes)
  totalCashValue   Float           @default(0) 
  
  // Value for Category-B (Gold Schemes)
  totalWeightGrams Float           @default(0) 
  
  isUsed           Boolean         @default(false)
  isActive         Boolean         @default(true) // Set to true for Return Coupons immediately
  usedAt           DateTime?
  
  // RELATIONS MADE OPTIONAL (?)
  // This allows you to create a coupon WITHOUT a scheme for returns
  customerSchemeId String?         @unique
  customerScheme   CustomerScheme? @relation(fields: [customerSchemeId], references: [id])
  
  // Link to Customer (Keep this mandatory if you want to track who owns the credit)
  customerId       String
  customer         Customer        @relation(fields: [customerId], references: [id])
  
  // Link to Scheme (Optional for Return Credits)
  schemeId         String?
  scheme           Scheme?         @relation(fields: [schemeId], references: [id])

  createdAt        DateTime        @default(now())
}
// ==========================================
// 5. CUSTOMER PROFILE
// ==========================================
model Customer {
  id        String           @id @default(uuid())
  name      String
  username  String           @unique
  password  String
  phone     String
  mpin      String?
  createdAt DateTime         @default(now())
  
  schemes   CustomerScheme[]
  coupons   Coupon[]
}
model OtpVerification {
  id            String    @id @default(cuid())
  phoneNumber   String    @db.VarChar(15)
  otpCode       String    @db.VarChar(6)
  purpose       String    @db.VarChar(50)
  requestedById String?
  attempts      Int       @default(0)
  isUsed        Boolean   @default(false)
  expiresAt     DateTime
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([phoneNumber])
  @@index([purpose])
  @@index([phoneNumber, purpose])
}

model ReturnCoupon {
  id          String   @id @default(uuid())
  code        String   @unique // The coupon code
  cashAmount  Float    // The credit value
  isUsed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  invoice         String      @default("#svn")

  creditNotes  CreditNote[]
}

model ProductImgs {
  id          String   @id @default(uuid())
  title       String
  description String?
  weight      Float
  image       Bytes
  mimeType    String   @default("image/jpeg")
  metalType   String   @default("gold")
  carats      String   @default("24k")
  createdAt   DateTime @default(now())
}
